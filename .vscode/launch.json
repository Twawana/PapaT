{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Titus VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": ["${workspaceFolder}/vscode-extension/dist/**/*.js"],
      "preLaunchTask": "Build Titus Extension",
      "timeout": 120000,
      "stopOnEntry": false,
      "sourceMaps": true
    }
  ]
}
