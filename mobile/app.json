{
  "expo": {
    "name": "Titus",
    "slug": "titus",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.titus.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "package": "com.titus.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Titus to scan the pairing QR code on your PC."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Titus to attach photos to agent prompts.",
          "cameraPermission": "Allow Titus to take photos for agent prompts."
        }
      ],
      "expo-secure-store"
    ]
  }
}
