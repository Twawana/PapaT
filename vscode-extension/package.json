{
  "name": "titus-vscode",
  "displayName": "Titus",
  "description": "Connect VS Code to Titus phone-as-PC terminal",
  "version": "0.5.0",
  "publisher": "titus",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "titus.connect",
        "title": "Titus: Connect to Host"
      },
      {
        "command": "titus.disconnect",
        "title": "Titus: Disconnect"
      },
      {
        "command": "titus.showStatus",
        "title": "Titus: Show Connection Status"
      }
    ],
    "configuration": {
      "title": "Titus",
      "properties": {
        "titus.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Titus host server address"
        },
        "titus.port": {
          "type": "number",
          "default": 3847,
          "description": "Titus host WebSocket port"
        },
        "titus.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Connect to Titus host when VS Code starts"
        },
        "titus.openFilesOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Focus files in VS Code when the phone saves them"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "npm run build"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.0",
    "typescript": "^5.8.2"
  }
}
